<Window x:Class="TrashAPP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:TrashAPP.ViewModels"
        xmlns:models="clr-namespace:TrashAPP.Core.Models"
        xmlns:local="clr-namespace:TrashAPP"
        mc:Ignorable="d"
        Title="垃圾识别系统" Height="850" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#FFF5F5F5">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <local:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
        <local:BoolToCollapsedConverter x:Key="BoolToCollapsedConverter"/>
        <local:BoolToVisibleConverter x:Key="BoolToVisibleConverter"/>
        <local:InverseBoolToVisibleConverter x:Key="InverseBoolToVisibleConverter"/>
        <local:EnumToBoolConverter x:Key="EnumToBoolConverter"/>

        <!-- 输入模式单选按钮样式 -->
        <Style x:Key="InputModeRadio" TargetType="RadioButton">
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- 状态标签样式 -->
        <Style x:Key="StatusLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ========== 左侧控制面板 ========== -->
        <Border Grid.Column="0" Background="White" BorderBrush="#FFE0E0E0" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16">

                    <!-- 标题 -->
                    <TextBlock Text="垃圾识别系统" FontSize="22" FontWeight="Bold" Margin="0,0,0,4" Foreground="#FF333333"/>
                    <TextBlock Text="基于 YOLO + ResNet18" FontSize="11" Foreground="#FF999999" Margin="0,0,0,16"/>

                    <!-- 模型状态 -->
                    <Border Background="#FFF0F7FF" BorderBrush="#FFBBDEFB" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="模型状态" FontWeight="Bold" FontSize="12" Foreground="#FF1976D2" Margin="0,0,0,8"/>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="检测模型:" FontSize="11" Foreground="#FF666666" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding DetectModelPath}" FontSize="11" Foreground="#FF333333" TextTrimming="CharacterEllipsis"/>
                            </Grid>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="分类模型:" FontSize="11" Foreground="#FF666666" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding ClassifyModelPath}" FontSize="11" Foreground="#FF333333" TextTrimming="CharacterEllipsis"/>
                            </Grid>
                            <TextBlock Text="{Binding ModelStatusMessage}" FontSize="10" Margin="0,4,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#FF4CAF50"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ModelsReady}" Value="False">
                                                <Setter Property="Foreground" Value="#FFF44336"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Button Content="刷新" Command="{Binding RefreshModelsCommand}" FontSize="10" Padding="8,2" Margin="0,4,0,0" HorizontalAlignment="Left">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Background" Value="#FF90CAF9"/>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- 输入方式 -->
                    <GroupBox Header="输入方式" Margin="0,0,0,12" BorderBrush="#FFE0E0E0">
                        <StackPanel Margin="8">
                            <RadioButton Style="{StaticResource InputModeRadio}"
                                         Content="单张图片"
                                         IsChecked="{Binding InputMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static models:InputMode.SingleImage}}"/>
                            <RadioButton Style="{StaticResource InputModeRadio}"
                                         Content="单个视频"
                                         IsChecked="{Binding InputMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static models:InputMode.SingleVideo}}"/>
                            <RadioButton Style="{StaticResource InputModeRadio}"
                                         Content="文件夹（图片）"
                                         IsChecked="{Binding InputMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static models:InputMode.FolderImages}}"/>
                            <RadioButton Style="{StaticResource InputModeRadio}"
                                         Content="文件夹（视频）"
                                         IsChecked="{Binding InputMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static models:InputMode.FolderVideos}}"/>
                            <RadioButton Style="{StaticResource InputModeRadio}"
                                         Content="摄像头流（TODO）"
                                         Foreground="#FF999999"
                                         IsEnabled="False"
                                         IsChecked="{Binding InputMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static models:InputMode.CameraStream}}"/>

                            <Separator Margin="0,8" Background="#FFE0E0E0"/>

                            <Button Content="选择输入源" Command="{Binding SelectSourceCommand}" Margin="0,4"/>
                            <TextBlock Text="{Binding SourcePath}" FontSize="11" Foreground="#FF666666" TextWrapping="Wrap" Margin="4,4,4,0"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- 输出配置 -->
                    <GroupBox Header="输出配置" Margin="0,0,0,12" BorderBrush="#FFE0E0E0">
                        <StackPanel Margin="8">
                            <!-- 输出方式 -->
                            <TextBlock Text="输出方式" FontSize="11" Foreground="#FF666666" Margin="4,4,4,2"/>
                            <ComboBox SelectedValue="{Binding OutputMode}" Margin="4,2" Padding="8,4">
                                <ComboBox.Items>
                                    <models:OutputMode>SaveToFile</models:OutputMode>
                                    <models:OutputMode>PreviewOnly</models:OutputMode>
                                    <models:OutputMode>PeriodicSnapshot</models:OutputMode>
                                    <models:OutputMode>RecordMkv</models:OutputMode>
                                </ComboBox.Items>
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding}"/>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <!-- 输出目录 -->
                            <StackPanel Visibility="{Binding ShowOutputDir, Converter={StaticResource BoolToVisibleConverter}}">
                                <TextBlock Text="输出目录" FontSize="11" Foreground="#FF666666" Margin="4,8,4,2"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding OutputDir}" IsReadOnly="True" FontSize="11"/>
                                    <Button Grid.Column="1" Content="浏览" Command="{Binding SelectOutputDirCommand}" Padding="8,4" Margin="4,0,0,0"/>
                                </Grid>
                            </StackPanel>

                            <!-- 周期性截图间隔 -->
                            <StackPanel Visibility="{Binding ShowPeriodicOptions, Converter={StaticResource BoolToVisibleConverter}}">
                                <TextBlock Margin="4,8,4,2">
                                    <Run Text="截图间隔: "/>
                                    <Run Text="{Binding SnapshotIntervalSeconds}" FontWeight="Bold"/>
                                    <Run Text=" 秒"/>
                                </TextBlock>
                                <Slider Minimum="1" Maximum="60" Value="{Binding SnapshotIntervalSeconds}" TickFrequency="1" IsSnapToTickEnabled="True" Margin="4,2"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <!-- 操作按钮 -->
                    <StackPanel Margin="0,0,0,12">
                        <Button Content="开始识别" Command="{Binding StartInferenceCommand}" IsEnabled="{Binding CanStartInference}" Background="#FF4CAF50" FontWeight="Bold" Padding="16,10"/>
                        <Button Content="取消" Command="{Binding CancelInferenceCommand}" IsEnabled="{Binding IsRunning}" Background="#FFF44336"/>
                    </StackPanel>

                    <!-- 进度 -->
                    <StackPanel Margin="0,0,0,12">
                        <ProgressBar Value="{Binding ProgressValue}" Maximum="100" Height="6" Margin="4" Background="#FFE0E0E0" BorderThickness="0">
                            <ProgressBar.Style>
                                <Style TargetType="ProgressBar">
                                    <Setter Property="Foreground" Value="#FF4CAF50"/>
                                </Style>
                            </ProgressBar.Style>
                        </ProgressBar>
                        <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#FF666666" TextWrapping="Wrap" Margin="4,4,4,0"/>
                        <TextBlock Text="{Binding ProcessedImages, StringFormat='已处理: {0} / {1}', TargetNullValue=''}" FontSize="11" Foreground="#FF999999" Margin="4,2,4,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFolderInput}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ========== 右侧结果区域 ========== -->
        <Grid Grid.Column="1" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="200"/>
            </Grid.RowDefinitions>

            <!-- 图片预览区 -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 原图 -->
                <Border Grid.Column="0" Background="White" BorderBrush="#FFE0E0E0" BorderThickness="1" CornerRadius="4">
                    <Grid>
                        <TextBlock Text="原图" FontWeight="Bold" Foreground="#FFCCCCCC" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16"
                                   Visibility="{Binding PreviewImage, Converter={StaticResource NullToVisibilityConverter}}"/>
                        <Image Source="{Binding PreviewImage}" Stretch="Uniform" Margin="8"/>
                    </Grid>
                </Border>

                <!-- 结果图 -->
                <Border Grid.Column="2" Background="White" BorderBrush="#FFE0E0E0" BorderThickness="1" CornerRadius="4">
                    <Grid>
                        <TextBlock Text="识别结果" FontWeight="Bold" Foreground="#FFCCCCCC" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16"
                                   Visibility="{Binding ResultImage, Converter={StaticResource NullToVisibilityConverter}}"/>
                        <Image Source="{Binding ResultImage}" Stretch="Uniform" Margin="8"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- 分隔线 -->
            <Separator Grid.Row="1" Margin="0,8" Background="#FFE0E0E0"/>

            <!-- 结果列表 -->
            <Border Grid.Row="2" Background="White" BorderBrush="#FFE0E0E0" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="检测结果" FontWeight="Bold" Margin="12,8,12,4" Foreground="#FF333333"/>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding CurrentDetections}" AutoGenerateColumns="False"
                              IsReadOnly="True" GridLinesVisibility="Horizontal" BorderThickness="0"
                              HeadersVisibility="Column" Margin="4">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="类别" Binding="{Binding ClassName}" Width="100"/>
                            <DataGridTextColumn Header="检测置信度" Binding="{Binding DetectionConfidence, StringFormat={}{0:F3}}" Width="100"/>
                            <DataGridTextColumn Header="分类置信度" Binding="{Binding ClassConfidence, StringFormat={}{0:F3}}" Width="100"/>
                            <DataGridTextColumn Header="位置" Binding="{Binding BoxPosition}" Width="150"/>
                            <DataGridTextColumn Header="面积比例" Binding="{Binding BoxAreaRatio, StringFormat={}{0:F3}}" Width="80"/>
                            <DataGridCheckBoxColumn Header="大框" Binding="{Binding IsBigBox}" Width="60"/>
                            <DataGridTextColumn Header="状态" Binding="{Binding StatusText}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Grid.Row="1" Text="暂无检测结果" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="#FFCCCCCC" FontSize="14"
                               Visibility="{Binding CurrentDetections.Count, Converter={StaticResource CountToVisibilityConverter}}"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
